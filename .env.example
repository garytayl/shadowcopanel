# Optional: where to store the activity timeline JSON (defaults to ./data/activity-events.json on the Next.js host)
# REFORGER_ACTIVITY_LOG_PATH=

# Optional: where to store saved server profiles from the Servers page (defaults to ./data/server-profiles.json)
# REFORGER_SERVER_PROFILES_PATH=

# --- Provision new VPS from the app (API keys on this host only; no console required) ---
#
# Amazon EC2 — IAM user (or role) with EC2: run/describe instances, key pairs, security groups, images.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# Optional: AWS_SESSION_TOKEN= (STS / assumed role)
# Optional: ingress CIDR for SSH + game UDP (default wide open — lock down in production)
# AWS_PROVISION_SG_CIDR=0.0.0.0/0
#
# DigitalOcean — create a token at https://cloud.digitalocean.com/account/api/tokens (read+write).
# DIGITALOCEAN_TOKEN=
# Optional: image slug (default ubuntu-22-04-x64)
# DIGITALOCEAN_DEFAULT_IMAGE=ubuntu-22-04-x64
#
# Hetzner Cloud (optional alternative)
# HETZNER_API_TOKEN=
# HETZNER_DEFAULT_IMAGE=ubuntu-22.04

# -----------------------------------------------------------------------------
# LOCAL SETUP (developers)
# Copy this file to ".env.local" and fill in values. Never commit .env.local.
#
# You do NOT put secrets in the game—this file is read only by the computer that
# runs this website (your laptop or your host, e.g. Vercel). Players never see it.
# -----------------------------------------------------------------------------

# --- How this app reaches your cloud game server ---
# REFORGER_SSH_HOST = public IP or hostname of the rented machine (from your host’s dashboard)
# REFORGER_SSH_USER = login name on that machine (often "ubuntu" on Ubuntu images)

REFORGER_SSH_HOST=
REFORGER_SSH_PORT=22
REFORGER_SSH_USER=ubuntu

# Private key: one of the two options below (not both required on every setup)
#
# Option A — On your own PC: path to the .pem file you downloaded when you created the server
REFORGER_SSH_PRIVATE_KEY_PATH=
#
# Option B — On Vercel / cloud hosting: paste the ENTIRE key text here (multiline OK in .env.local).
# On Vercel, use the dashboard “Environment variables” and paste the same key. Leave PATH empty there.
# REFORGER_SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# --- Folders on the game machine (defaults match typical Ubuntu installs) ---
REFORGER_SERVER_PATH=/home/ubuntu/arma-reforger
REFORGER_CONFIG_PATH=/home/ubuntu/arma-reforger/config.json

# Name of the background “session” that keeps the game running after you disconnect
REFORGER_TMUX_SESSION=reforger

# Command used to start the Reforger binary (after changing into REFORGER_SERVER_PATH)
REFORGER_SERVER_CMD='./ArmaReforgerServer -config ./config.json -maxFPS 60'

# Optional: exact log file on the game server (overrides auto-discovery).
# Auto-discovery picks the newest *.log under REFORGER_SERVER_PATH and under
# /home/<REFORGER_SSH_USER>/.config/ArmaReforger/logs (Linux/XDG — console.log, error.log, …).
# REFORGER_LOG_GLOB=/home/ubuntu/.config/ArmaReforger/logs/logs_2026-04-03_03-41-10/console.log

# Optional: which port number to highlight on the Home page (often your game port)
REFORGER_CHECK_PORT=2001

# Optional: short note shown on the Home page (e.g. “Chicago server”)
REFORGER_INSTANCE_NOTES=

# Optional: banner text for everyone on the Home page (maintenance, events, etc.)
# REFORGER_ANNOUNCEMENT=Server restart tonight at 2am UTC
