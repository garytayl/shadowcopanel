# =============================================================================
# WHO READS THIS
# =============================================================================
# Only the machine that runs Next.js (Vercel, your VPS, or your laptop).
# End users configure servers in the app — IPs and SSH keys are NOT static env vars.
# =============================================================================

# -----------------------------------------------------------------------------
# HOSTED (e.g. Vercel) — put these in the dashboard (Production + Preview as needed)
# -----------------------------------------------------------------------------
# Durable state for “Server setup”, saved AWS keys, and one-click launch (auto-generated SSH keys).
# Create a Redis database at https://upstash.com → connect to Vercel → these appear:
#
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
#
# Optional global banner on the Home page:
# REFORGER_ANNOUNCEMENT=
#
# Do NOT set REFORGER_SSH_HOST / REFORGER_SSH_PRIVATE_KEY* here for normal use.
# Connections are added in the app (stored in Redis above).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# OPTIONAL — operators only: AWS keys in env instead of “Server setup”
# -----------------------------------------------------------------------------
# If set, they override saved-in-app credentials. Leave unset so users paste keys once in the UI.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# Optional: AWS_SESSION_TOKEN=
# Optional: AWS_PROVISION_SG_CIDR=0.0.0.0/0

# -----------------------------------------------------------------------------
# LOCAL DEV — .env.local (no Redis: uses files under ./data/ instead)
# -----------------------------------------------------------------------------
# Copy this file to ".env.local". You can either:
#   • Use Server setup in the app (saved to data/server-profiles.json), or
#   • Set SSH below so the panel defaults to one machine without clicking “Use this server”.
#
# REFORGER_SSH_HOST=
# REFORGER_SSH_PORT=22
# REFORGER_SSH_USER=ubuntu
# REFORGER_SSH_PRIVATE_KEY_PATH=
# REFORGER_SSH_PRIVATE_KEY=
# REFORGER_SERVER_PATH=/home/ubuntu/arma-reforger
# REFORGER_CONFIG_PATH=/home/ubuntu/arma-reforger/config.json
# REFORGER_TMUX_SESSION=reforger
# REFORGER_SERVER_CMD='./ArmaReforgerServer -config ./config.json -maxFPS 60'
# REFORGER_CHECK_PORT=2001
# REFORGER_INSTANCE_NOTES=

# -----------------------------------------------------------------------------
# OPTIONAL paths (advanced; local or persistent disk only)
# -----------------------------------------------------------------------------
# REFORGER_ACTIVITY_LOG_PATH=
# REFORGER_SERVER_PROFILES_PATH=
# REFORGER_AWS_CREDENTIALS_PATH=
