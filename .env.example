# Copy to .env.local and fill in. Never commit .env.local.
# This app runs SSH from the Next.js server only (never ship keys to the browser).
#
# Where does the PEM live?
# - Local dev (Mac/PC): put the key somewhere stable (not Downloads long-term), e.g.
#   ~/.ssh/arma-reforger.pem — then set REFORGER_SSH_PRIVATE_KEY_PATH only.
# - Vercel / serverless: no reliable disk path. Paste the full private key into
#   REFORGER_SSH_PRIVATE_KEY in the Vercel env UI (encrypted). Leave PATH empty.

# --- SSH (required for remote control) ---
REFORGER_SSH_HOST=
REFORGER_SSH_PORT=22
REFORGER_SSH_USER=ubuntu

# Local file path to PEM. Omit on Vercel if using REFORGER_SSH_PRIVATE_KEY instead.
REFORGER_SSH_PRIVATE_KEY_PATH=

# Full key text (required for Vercel). Use \n between lines if you use a single-line value.
# REFORGER_SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# --- Remote paths (Ubuntu EC2 defaults) ---
REFORGER_SERVER_PATH=/home/ubuntu/arma-reforger
REFORGER_CONFIG_PATH=/home/ubuntu/arma-reforger/config.json
REFORGER_TMUX_SESSION=reforger

# Command run inside tmux (after cd to REFORGER_SERVER_PATH)
REFORGER_SERVER_CMD='./ArmaReforgerServer -config ./config.json -maxFPS 60'

# Optional: fixed log file to tail instead of auto-discovery under REFORGER_SERVER_PATH
# REFORGER_LOG_GLOB=/home/ubuntu/arma-reforger/logs/console.log

# Optional: port string passed to `ss ... | grep` on the dashboard (game/query port)
REFORGER_CHECK_PORT=2001

# Free-form notes shown on the dashboard (non-secret)
REFORGER_INSTANCE_NOTES=
